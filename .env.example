# Gemini API Key - https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend API URL (frontend uses this to call backend)
# Dev: leave empty (vite proxy handles /api → localhost:8000)
# Production: set to your deployed backend URL
VITE_API_URL=

# Backend Database
DATABASE_URL=sqlite:///./edusmart.db

# CORS allowed origins (comma separated, production URLs add කරන්න)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin credentials
ADMIN_EMAIL=admin@edusmart.lk
ADMIN_PASSWORD=YourSecurePassword@2024

# JWT Secret Key - production හිදී strong random string use කරන්න
SECRET_KEY=your-secret-key-change-in-production
